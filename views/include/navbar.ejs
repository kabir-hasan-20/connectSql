<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">

  <div class="container">

    <!-- Logo -->
    <a class="navbar-brand fw-bold fs-4" href="/">

      <i class="fa-solid fa-blog me-2 text-success"></i>

      ConnectSQL

    </a>

    <!-- Mobile Button -->
    <button 
      class="navbar-toggler border-0 shadow-none"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >

      <span class="navbar-toggler-icon"></span>

    </button>

    <!-- Navbar -->
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

      <!-- Left -->
      <div class="navbar-nav mx-auto gap-lg-3">

        <a 
          class="nav-link nav-hover"
          href="/"
        >
          <i class="fa-solid fa-house me-1"></i>
          Home
        </a>

        <a 
          class="nav-link nav-hover"
          href="/"
        >
          <i class="fa-solid fa-layer-group me-1"></i>
          All Posts
        </a>

        <% if(currentUser){ %>

          <a 
            class="nav-link nav-hover"
            href="/post/create"
          >
            <i class="fa-solid fa-plus me-1"></i>
            Add Post
          </a>

        <% } %>

      </div>

      <!-- Right -->
      <div class="navbar-nav align-items-lg-center gap-lg-2">

        <% if(currentUser){ %>

          <!-- Profile -->
          <a 
            class="nav-link nav-hover d-flex align-items-center"
            href="/profile"
          >

            <% if(currentUser.profile_img){ %>

              <img 
                src="<%= currentUser.profile_img %>"
                class="rounded-circle me-2 border border-2 border-success"
                width="35"
                height="35"
                style="object-fit:cover;"
              >

            <% } else { %>

              <img 
                src="https://ui-avatars.com/api/?name=<%= currentUser.username %>&background=198754&color=fff"
                class="rounded-circle me-2"
                width="35"
                height="35"
              >

            <% } %>

            <span>
              <%= currentUser.username %>
